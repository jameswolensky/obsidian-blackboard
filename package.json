{
  "name": "obsidian-blackboard",
  "version": "1.2.1",
  "description": "Native stylus and Apple Pencil drawing for Obsidian, with live drawing in Canvas and Markdown embeds.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run lint && npm run test && npm run build",
    "preversion": "npm run check",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "postversion": "git push --follow-tags origin HEAD",
    "release:patch": "npm version patch -m \"release: %s\"",
    "release:minor": "npm version minor -m \"release: %s\"",
    "release:major": "npm version major -m \"release: %s\"",
    "scan": "eslint src && node scripts/scan-guards.mjs",
    "test:e2e": "wdio run wdio.desktop.conf.mts",
    "test:e2e:mobile": "wdio run wdio.mobile.conf.mts",
    "lint": "eslint src"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "apple-pencil",
    "stylus",
    "drawing",
    "handwriting",
    "canvas",
    "ipad"
  ],
  "author": "James Wolensky",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@jaames/iro": "^5.5.2",
    "perfect-freehand": "^1.2.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@wdio/cli": "^9.29.1",
    "@wdio/local-runner": "^9.29.1",
    "@wdio/mocha-framework": "^9.29.1",
    "@wdio/spec-reporter": "^9.29.1",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.4.1",
    "jsdom": "^29.0.1",
    "mocha": "^10.8.2",
    "obsidian": "^1.13.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.1",
    "wdio-obsidian-reporter": "^3.1.1",
    "wdio-obsidian-service": "^3.1.1"
  }
}
