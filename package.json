{
  "name": "obsidian-blackboard",
  "version": "1.0.0",
  "description": "Native stylus and Apple Pencil drawing for Obsidian, with live drawing in Canvas and Markdown embeds.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run test && npm run build",
    "preversion": "npm run check",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "postversion": "git push --follow-tags origin HEAD",
    "release:patch": "npm version patch -m \"release: %s\"",
    "release:minor": "npm version minor -m \"release: %s\"",
    "release:major": "npm version major -m \"release: %s\""
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "apple-pencil",
    "stylus",
    "drawing",
    "handwriting",
    "canvas",
    "ipad"
  ],
  "author": "James Wolensky",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@jaames/iro": "^5.5.2",
    "perfect-freehand": "^1.2.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "builtin-modules": "^5.3.0",
    "esbuild": "^0.27.4",
    "jsdom": "^29.0.1",
    "obsidian": "^1.12.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
